{
	"manifest_version": 3,
	"name": "Kueski Pay - Asistente de Compras",
	"version": "1.0.0",
	"description": "Centro de control, simulación de crédito y cashback en tiempo real para tus compras en línea.",
	"icons": {
		"48": "assets/icons/icon48.png"
	},

	"permissions": ["storage", "tabs"],
	"host_permissions": ["https://*/*"],

	"background": {
		"service_worker": "background/background.js",
		"scripts": ["background/background.js"]
	},

	"action": {
		"default_popup": "popup/popup.html",
		"default_title": "Abrir Centro de Control"
	},

	"content_scripts": [
		{
			"matches": ["<all_urls>"],
			"js": ["content/content-script.js"],
			"run_at": "document_end"
		}
	],

	"web_accessible_resources": [
		{
			"resources": ["assets/kueski.png"],
			"matches": ["<all_urls>"]
		}
	]
}
