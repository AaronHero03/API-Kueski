{
	"manifest_version": 3,
	"name": "Kueski Helper",
	"version": "1.0.0",
	"description": "Gestiona tu saldo y cashback de Kueski de forma rápida y segura.",
	"icons": {
		"48": "assets/icons/icon48.png"
	},

	"action": {
		"default_popup": "popup/popup.html",
		"default_title": "Abrir Kueski Helper"
	},

	"background": {
		"service_worker": "background/service-worker.js",
		"type": "module"
	},

	"content_scripts": [
		{
			"matches": ["https://*.tienda-afiliada.com/*"],
			"js": ["content/content.js"],
			"css": ["content/content.css"]
		}
	],

	"permissions": ["storage", "alarms"],

	"host_permissions": ["https://api.tu-dominio-interno.com/*"]
}
